                        </subviews>
                        <viewLayoutGuide key="safeArea" id="launch-safe-area"/>
                        <color key="backgroundColor" white="0.0" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                        <constraints>
                            <constraint firstItem="launch-copy-stack" firstAttribute="bottom" secondItem="launch-safe-area" secondAttribute="bottom" constant="-24" id="launch-copy-bottom"/>
                            <constraint firstItem="launch-copy-stack" firstAttribute="centerX" secondItem="launch-root-view" secondAttribute="centerX" id="launch-copy-center-x"/>
                            <constraint firstItem="launch-copy-stack" firstAttribute="leading" relation="greaterThanOrEqual" secondItem="launch-root-view" secondAttribute="leading" constant="40" id="launch-copy-leading-min"/>
                            <constraint firstAttribute="trailing" relation="greaterThanOrEqual" secondItem="launch-copy-stack" secondAttribute="trailing" constant="40" id="launch-copy-trailing-min"/>
                            <constraint firstItem="launch-mark-view" firstAttribute="centerX" secondItem="launch-root-view" secondAttribute="centerX" id="launch-mark-center-x"/>
